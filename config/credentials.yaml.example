# Cliniconex Intelligence Center — Credentials Template
# Copy this file to credentials.yaml and fill in real values
# NEVER commit credentials.yaml to git

activecampaign:
  api_url: https://cliniconexmarketing.api-us1.com
  api_key: YOUR_AC_API_KEY_HERE

google_ads:
  developer_token: YOUR_DEVELOPER_TOKEN
  client_id: YOUR_CLIENT_ID
  client_secret: YOUR_CLIENT_SECRET
  refresh_token: YOUR_REFRESH_TOKEN
  customer_id: "4135262293"
  login_customer_id: "4135262293"

anthropic:
  api_key: YOUR_ANTHROPIC_API_KEY

gemini:
  api_key: YOUR_GEMINI_API_KEY_HERE

# Google Sheets — manual KPI entry persistence
# Create a service account in your GCP project, download the JSON key,
# and share the spreadsheet with the service account email.
google_sheets:
  spreadsheet_id: YOUR_SPREADSHEET_ID_HERE
  service_account_file: google-sheets-sa.json

# JIRA Cloud — Product tab KPIs (say/do ratio, strategic allocation, etc.)
# Generate an API token at https://id.atlassian.com/manage-profile/security/api-tokens
jira:
  site_url: https://cliniconex.atlassian.net
  email: YOUR_ATLASSIAN_EMAIL
  api_token: YOUR_JIRA_API_TOKEN
  project_key: DELIVERY
