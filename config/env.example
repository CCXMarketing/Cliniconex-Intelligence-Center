# Sevalla Environment Variables Reference
# Set these in Sevalla Dashboard → Application → Environment Variables
# These replace credentials.yaml in production

AC_API_URL=https://cliniconexmarketing.api-us1.com
AC_API_KEY=your_activecampaign_api_key

GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_client_id
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_CUSTOMER_ID=4135262293
GOOGLE_ADS_LOGIN_CUSTOMER_ID=4135262293

ANTHROPIC_API_KEY=your_anthropic_api_key

GEMINI_API_KEY=your_google_ai_studio_api_key

# JIRA Cloud — Product tab KPIs
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_SITE_URL=https://cliniconex.atlassian.net
JIRA_EMAIL=your_atlassian_email
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=DELIVERY

# Salesforce — Sales / CS / Exec KPIs
# Get the Connected App keys + integration user from your SF admin.
# Set SF_DOMAIN=test for a sandbox.
SF_INSTANCE_URL=https://cliniconex.my.salesforce.com
SF_USERNAME=integration-user@cliniconex.com
SF_PASSWORD=your_sf_password
SF_SECURITY_TOKEN=your_sf_security_token
SF_CONSUMER_KEY=your_connected_app_consumer_key
SF_CONSUMER_SECRET=your_connected_app_consumer_secret
SF_DOMAIN=login
SF_MRR_FIELD=Amount

# KPI snapshot DB (SQLite) — populated by write-through on every successful
# upstream fetch. Defaults to <project_root>/data/cic.db; override for
# deployments where the project root is read-only.
CIC_SNAPSHOT_DB=/opt/cic/data/cic.db

SECRET_KEY=generate_a_long_random_string_here
PORT=8080
